# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
ALLOWED_EMAILS=

# Session security — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=
# Set to true in production (enables Secure flag on session cookie)
HTTPS_ONLY=true

# Ollama — endpoint is the Cloudflare Tunnel URL in production
OLLAMA_ENDPOINT=https://ollama.nonoise.us
OLLAMA_MODEL=
# Cloudflare Access service token (required when endpoint is behind CF Access)
OLLAMA_CF_CLIENT_ID=
OLLAMA_CF_CLIENT_SECRET=
# Inference tuning (defaults shown)
OLLAMA_TEMPERATURE=0.3
OLLAMA_NUM_PREDICT=12
OLLAMA_TOP_K=40
OLLAMA_TOP_P=0.95
OLLAMA_REPEAT_PENALTY=1.1

# Storage paths (Docker volume mounts — leave as-is unless changed in compose)
UPLOAD_DIR=./uploads
DATABASE_PATH=./data/puzzle.db

# Retention
SESSION_RETENTION_DAYS=30
AUTOSAVE_INTERVAL_SECONDS=120
